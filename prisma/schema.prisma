generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Position Registry ──────────────────────────────────────────

model Position {
  id                  String    @id // position address
  pool                String
  poolName            String?   @map("pool_name")
  strategy            String?
  binRange            Json?     @map("bin_range")
  amountSol           Float?    @map("amount_sol")
  amountX             Float?    @map("amount_x")
  activeBinAtDeploy   Int?      @map("active_bin_at_deploy")
  binStep             Int?      @map("bin_step")
  volatility          Float?
  feeTvlRatio         Float?    @map("fee_tvl_ratio")
  initialFeeTvl24h    Float?    @map("initial_fee_tvl_24h")
  organicScore        Float?    @map("organic_score")
  initialValueUsd     Float?    @map("initial_value_usd")
  deployedAt          DateTime  @default(now()) @map("deployed_at")
  outOfRangeSince     DateTime? @map("out_of_range_since")
  lastClaimAt         DateTime? @map("last_claim_at")
  totalFeesClaimed    Float     @default(0) @map("total_fees_claimed_usd")
  rebalanceCount      Int       @default(0) @map("rebalance_count")
  closed              Boolean   @default(false)
  closedAt            DateTime? @map("closed_at")
  instruction         String?
  notes               Json      @default("[]")

  @@map("positions")
}

// ─── Recent Events ──────────────────────────────────────────────

model RecentEvent {
  id        Int      @id @default(autoincrement())
  ts        DateTime @default(now())
  action    String
  position  String?
  poolName  String?  @map("pool_name")
  reason    String?
  data      Json?

  @@map("recent_events")
}

// ─── Performance Records ────────────────────────────────────────

model Performance {
  id              Int      @id @default(autoincrement())
  position        String
  pool            String
  poolName        String?  @map("pool_name")
  baseMint        String?  @map("base_mint")
  strategy        String?
  binRange        Int?     @map("bin_range")
  binStep         Int?     @map("bin_step")
  volatility      Float?
  feeTvlRatio     Float?   @map("fee_tvl_ratio")
  organicScore    Float?   @map("organic_score")
  amountSol       Float?   @map("amount_sol")
  feesEarnedUsd   Float?   @map("fees_earned_usd")
  finalValueUsd   Float?   @map("final_value_usd")
  initialValueUsd Float?   @map("initial_value_usd")
  minutesInRange  Int?     @map("minutes_in_range")
  minutesHeld     Int?     @map("minutes_held")
  closeReason     String?  @map("close_reason")
  pnlUsd          Float?   @map("pnl_usd")
  pnlPct          Float?   @map("pnl_pct")
  rangeEfficiency Float?   @map("range_efficiency")
  deployedAt      DateTime? @map("deployed_at")
  recordedAt      DateTime @default(now()) @map("recorded_at")

  @@map("performance")
}

// ─── Lessons ────────────────────────────────────────────────────

model Lesson {
  id        Int      @id @default(autoincrement())
  rule      String
  tags      String[] @default([])
  outcome   String?
  pinned    Boolean  @default(false)
  role      String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("lessons")
}

// ─── Pool Memory ────────────────────────────────────────────────

model PoolMemory {
  id        Int      @id @default(autoincrement())
  pool      String
  snapshot Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("pool_memory")
}

// ─── Global Configuration ──────────────────────────────────────

model Config {
  id        Int      @id @default(1)
  data      Json     @default("{}")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("config")
}

// ─── API Keys & Secrets ──────────────────────────────────────────

model Secret {
  id        String   @id @default(cuid())
  key       String   @unique // e.g., "OPENROUTER_API_KEY", "RPC_URL"
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("secrets")
}

// ─── Smart Wallets ──────────────────────────────────────────────

model SmartWallet {
  id       Int      @id @default(autoincrement())
  name     String
  address  String   @unique
  category String   @default("alpha")
  type     String   @default("lp")
  addedAt  DateTime @default(now()) @map("added_at")

  @@map("smart_wallets")
}

// ─── Token Blacklist ────────────────────────────────────────────

model TokenBlacklist {
  mint    String   @id
  symbol  String   @default("UNKNOWN")
  reason  String?
  addedAt DateTime @default(now()) @map("added_at")
  addedBy String   @default("agent") @map("added_by")

  @@map("token_blacklist")
}
