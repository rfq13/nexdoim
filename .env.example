# ─── Required ───────────────────────────────────────
DATABASE_URL=postgresql://user:pass@host:5432/meridian
WALLET_PRIVATE_KEY=your_base58_private_key
RPC_URL=https://api.mainnet-beta.solana.com
OPENROUTER_API_KEY=sk-or-...

# ─── Optional: Telegram ────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Optional: LLM Overrides ──────────────────────
LLM_BASE_URL=
LLM_MODEL=

# ─── Optional: Enhanced Data ──────────────────────
HELIUS_API_KEY=
LPAGENT_API_KEY=

# ─── Optional: Hive Mind ─────────────────────────
HIVE_MIND_URL=
HIVE_MIND_API_KEY=

# ─── Optional: Modes ─────────────────────────────
DRY_RUN=false
LOG_LEVEL=info
PORT=3000

# ─── Heroku sets this automatically ──────────────
# PORT is set by Heroku, no need to configure
